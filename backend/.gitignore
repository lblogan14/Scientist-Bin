# Byte-compiled / optimized
__pycache__/
*.py[cod]
*.pyo

# C extensions
*.so

# Distribution / packaging
dist/
build/
*.egg-info/

# Virtual environments
.venv/
venv/

# Framework virtual environments (provisioned locally)
framework_venvs/*/.venv/

# Environment variables
.env

# Tool caches
.ruff_cache/
.mypy_cache/
.pytest_cache/

# Coverage
.coverage
htmlcov/

# Data and outputs (contents git-ignored)
data/*
!data/.gitkeep
!data/iris_data/
!data/ames_data/
!data/cc_data/
!data/mall_data/
!data/wine_data/
!data/electric_data/
outputs/*
!outputs/.gitkeep
